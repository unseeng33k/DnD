# D&D Game Engine Environment Variables
# Copy this file to .env and fill in your actual API keys
# NEVER commit .env to git - it's already in .gitignore

# =============================================================================
# AI / LLM APIs (Required for narrator and image generation)
# =============================================================================

# OpenAI - DALL-E image generation
OPENAI_API_KEY=sk-proj-...

# Anthropic - Claude narrator
ANTHROPIC_API_KEY=sk-ant-...

# Moonshot Kimi - Alternative LLM
MOONSHOT_API_KEY=sk-...

# Gemini - Alternative LLM
GEMINI_API_KEY=AIzaSy...

# =============================================================================
# Image & Search APIs (Optional)
# =============================================================================

# Unsplash - Free images
UNSPLASH_ACCESS_KEY=...
UNSPLASH_SECRET_KEY=...

# Brave Search - Web search
BRAVE_API_KEY=BSA...

# =============================================================================
# Social / Messaging APIs (Optional)
# =============================================================================

# Telegram Bot - For notifications
TELEGRAM_BOT_TOKEN=...:...

# X/Twitter - For posting
X_API_KEY=...
X_API_SECRET=...
X_ACCESS_TOKEN=...
X_ACCESS_SECRET=...

# LinkedIn - For posting
LINKEDIN_ACCESS_TOKEN=AQX...

# =============================================================================
# Cloud Services (Optional)
# =============================================================================

# Adobe PDF Services - For PDF manipulation
ADOBE_CLIENT_ID=...
ADOBE_CLIENT_SECRET=...

# Google Cloud - For various integrations
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

# Dropbox - For file storage
DROPBOX_ACCESS_TOKEN=...

# =============================================================================
# Data / Research APIs (Optional)
# =============================================================================

# Hunter.io - Email finder
HUNTER_API_KEY=...

# US Census - Demographic data
CENSUS_API_KEY=...

# =============================================================================
# Local Development (Required for local features)
# =============================================================================

# iMessage / BlueBubbles (Mac only)
BLUEBUBBLES_SERVER_URL=https://...
BLUEBUBBLES_PASSWORD=...

# =============================================================================
# D&D Specific (Optional - defaults provided)
# =============================================================================

# Default campaign module
DEFAULT_CAMPAIGN=tamoachan

# Image generation style
IMAGE_STYLE=cinematic

# Debug mode
DEBUG=false
